{
  "$schema": "ProspUp Design Tokens v1",
  "brand": {
    "accent":       "#FF6B35",
    "accentLight":  "#FF8C42",
    "accentSoft":   "rgba(255,107,53,0.12)",
    "accentDim":    "rgba(255,107,53,0.60)",
    "gradient":     "linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%)"
  },

  "theme": {
    "dark": {
      "bg":        "#000000",
      "bg2":       "#0A0A0D",
      "bg3":       "#121217",
      "bg4":       "#1C1C22",
      "text":      "#F5F5F7",
      "text2":     "rgba(235,235,245,0.60)",
      "text3":     "rgba(235,235,245,0.35)",
      "text4":     "rgba(235,235,245,0.18)",
      "border":    "rgba(255,255,255,0.06)",
      "border2":   "rgba(255,255,255,0.10)",
      "divider":   "rgba(84,84,88,0.40)",
      "glass":     "rgba(28,28,34,0.72)"
    },
    "light": {
      "bg":        "#F6F5F2",
      "bg2":       "#FAF9F6",
      "bg3":       "#FFFFFF",
      "bg4":       "#F0EFEB",
      "text":      "#1A1916",
      "text2":     "rgba(60,60,67,0.65)",
      "text3":     "rgba(60,60,67,0.35)",
      "text4":     "rgba(60,60,67,0.18)",
      "border":    "rgba(0,0,0,0.06)",
      "border2":   "rgba(0,0,0,0.10)",
      "divider":   "rgba(60,60,67,0.10)",
      "glass":     "rgba(255,255,255,0.72)"
    }
  },

  "status": {
    "appele":       { "fg": "#60A5FA", "bg": "rgba(59,130,246,0.15)",  "dot": "#3B82F6", "label": "Appelé" },
    "rdv":          { "fg": "#4ADE80", "bg": "rgba(34,197,94,0.15)",   "dot": "#22C55E", "label": "RDV" },
    "prospecte":    { "fg": "#C084FC", "bg": "rgba(168,85,247,0.15)",  "dot": "#A855F7", "label": "Prospecté" },
    "messagerie":   { "fg": "#FBBF24", "bg": "rgba(245,158,11,0.15)",  "dot": "#F59E0B", "label": "Messagerie" },
    "rappeler":     { "fg": "#FB923C", "bg": "rgba(249,115,22,0.15)",  "dot": "#F97316", "label": "À rappeler" },
    "pasInteresse": { "fg": "#F87171", "bg": "rgba(239,68,68,0.15)",   "dot": "#EF4444", "label": "Pas intéressé" },
    "neutre":       { "fg": "#94A3B8", "bg": "rgba(148,163,184,0.15)", "dot": "#64748B", "label": "—" }
  },

  "semantic": {
    "success": "#4ADE80",
    "warning": "#FBBF24",
    "danger":  "#F87171",
    "info":    "#60A5FA"
  },

  "radius": { "sm": 8, "md": 12, "lg": 18, "xl": 24, "xxl": 28, "pill": 999 },

  "spacing": {
    "screen_padding_x": 16,
    "card_padding": 14,
    "section_gap": 22,
    "row_gap": 6
  },

  "type": {
    "family_display": "-apple-system, \"SF Pro Display\", system-ui, sans-serif",
    "family_text":    "-apple-system, \"SF Pro Text\", system-ui, sans-serif",
    "family_mono":    "ui-monospace, \"SF Mono\", Menlo, monospace",
    "scale": {
      "largeTitle": { "size": 34, "weight": 700, "spacing": -0.8, "line": 1.1 },
      "title1":     { "size": 28, "weight": 700, "spacing": -0.8 },
      "title2":     { "size": 22, "weight": 700, "spacing": -0.5 },
      "headline":   { "size": 17, "weight": 600, "spacing": -0.3 },
      "body":       { "size": 15, "weight": 400, "spacing": -0.2 },
      "callout":    { "size": 14, "weight": 500, "spacing": -0.2 },
      "subhead":    { "size": 13, "weight": 500, "spacing": -0.1 },
      "footnote":   { "size": 12, "weight": 500 },
      "caption":    { "size": 11, "weight": 600, "spacing":  0.3, "upper": true },
      "caption2":   { "size": 10, "weight": 700, "spacing":  0.4, "upper": true }
    }
  },

  "shadow": {
    "card_dark":   "0 1px 0 rgba(255,255,255,0.02)",
    "card_light":  "0 1px 2px rgba(0,0,0,0.04)",
    "pop":         "0 10px 24px rgba(255,107,53,0.35)",
    "sheet_dark":  "0 30px 60px rgba(0,0,0,0.5)",
    "sheet_light": "0 30px 60px rgba(0,0,0,0.12)"
  },

  "glass": {
    "blur":         24,
    "saturate":     180,
    "border_dark":  "rgba(255,255,255,0.08)",
    "border_light": "rgba(0,0,0,0.06)"
  },

  "device": {
    "reference": "iPhone 17 Pro",
    "width":  402,
    "height": 874,
    "safe_top": 54,
    "safe_bottom": 34,
    "tabbar_height": 64,
    "tabbar_inset": { "bottom": 16, "x": 12 }
  }
}

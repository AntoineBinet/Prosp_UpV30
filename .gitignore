# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Node / Playwright
node_modules/
test-results/
playwright-report/

# Secrets & config
.env
.env.local
.secret_key
.recovery_token
scripts/.agent-secret
scripts/.cursor-api-key
# User runtime data (avatars, photos, user DBs, AI config)
data/*
# Exception : la toile d'araignée a besoin des résultats de test pour
# afficher les pastilles 🟢🟠🔴 en prod aussi.
!data/sitemap_status.json

# Databases
*.db
*.db-shm
*.db-wal
*.db-journal

# Runtime state
.last_commit_hash
.rollback_done
.supervisor_pid
.claude/settings.local.json

# Logs
logs/
*.log
!tests/**/*.log

# Generated outputs
outputs/dossiers/*.pdf
outputs/dossiers/*.docx

# Local snapshots / backups (manual workflow)
snapshots/
backups/

# Misc Windows artefacts
nul
Thumbs.db
